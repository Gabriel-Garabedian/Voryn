# ──────────────────────────────────────────────────────────
#  Voryn — Variáveis de Ambiente
#  Copie este arquivo para .env.local e preencha os valores
# ──────────────────────────────────────────────────────────

# ── Supabase (obrigatório) ─────────────────────────────────
VITE_SUPABASE_URL=https://XXXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# ── Mercado Pago (obrigatório para pagamentos) ─────────────
VITE_MP_PUBLIC_KEY=APP_USR-...
# A chave secreta NUNCA vai no frontend — apenas nas Edge Functions

# ── Push Notifications (opcional, mas recomendado) ─────────
# Gerar em: https://vapidkeys.com ou npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=BNtKe...

# ── Sentry (opcional, mas recomendado para produção) ────────
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ── Mercado Pago — IDs dos planos recorrentes ─────────────────
# Criar em: mercadopago.com.br/developers > Assinaturas > Criar plano
# Após criar cada plano, copiar o preapproval_plan_id
VITE_MP_PLAN_STUDENT=  # preapproval_plan_id do Plano Aluno (R$14,90/mês)
VITE_MP_PLAN_PERSONAL= # preapproval_plan_id do Plano Personal (R$59,90/mês)
VITE_MP_PLAN_PRO=      # preapproval_plan_id do Personal Pro (R$99,90/mês)

# ── App Info ───────────────────────────────────────────────
VITE_APP_VERSION=4.0.0
VITE_APP_URL=https://vorynapp.com.br

# ── Variáveis das Edge Functions (configurar no painel Supabase) ──
# MP_ACCESS_TOKEN=      → mercadopago.com.br > Credenciais > Access Token de produção
# MP_PLAN_STUDENT=      → preapproval_plan_id do Plano Aluno
# MP_PLAN_PERSONAL=     → preapproval_plan_id do Plano Personal
# MP_PLAN_PRO=          → preapproval_plan_id do Personal Pro
# MP_WEBHOOK_SECRET=   → painel MP > Credenciais > Chave secreta do webhook
# SUPABASE_SERVICE_KEY= → gerado automaticamente
# RESEND_API_KEY=      → https://resend.com (plano free: 3.000 emails/mês)
# CRON_SECRET=         → string aleatória para proteger o cron manual
